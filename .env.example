# =============================================================================
# NOVA AI - Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- Application ---
NODE_ENV=production
PORT=3000
APP_NAME=sentinel

# --- Database (MySQL) ---
DATABASE_URL=mysql://user:password@localhost:3306/sentinel

# --- Auth / JWT ---
# Generate a random secret: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this

# --- OpenAI (AI Chat & Tools) ---
OPENAI_API_KEY=sk-...

# --- ElevenLabs (Text-to-Speech) ---
ELEVENLABS_API_KEY=...

# --- Google Calendar / Gmail OAuth ---
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...

# --- Spotify OAuth ---
# Create app at: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=...
SPOTIFY_CLIENT_SECRET=...

# --- Microsoft (Outlook Calendar) OAuth ---
# Register app at: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
MICROSOFT_CLIENT_ID=...
MICROSOFT_CLIENT_SECRET=...

# --- Stripe (Billing) ---
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO=price_...

# --- Simple Routing API (Maps Directions) ---
# Get API key at: https://simplerouting.com/
SIMPLE_ROUTING_API_KEY=...

# --- Admin User ---
# Email of the first admin user (used for initial setup)
ADMIN_EMAIL=admin@example.com
